# Change to your actual Render URL after deployment
BASE_URL=http://localhost:3000

# Secret for session encryption (must be changed to a random value in production)
SESSION_SECRET=change-me-in-production

# Client credentials used in Shopify's SSO provider settings
# Register these same values in Shopify
CLIENT_ID=my-sso-client-id
CLIENT_SECRET=my-sso-client-secret

# Shopify Admin API version (e.g. "2026-04") — used in Admin GraphQL endpoint URL
SHOPIFY_ADMIN_API_VERSION=2026-04

# Shopify app credentials — used to verify session tokens and perform OAuth
# SHOPIFY_API_KEY: the API key (client_id) of your Shopify app
# SHOPIFY_API_SECRET: the API secret key (used to verify HS256 session tokens and sign OAuth requests)
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret-key
